{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "instructions": [
    "../AGENTS.md"
  ],
  "agent": {
    "orchestrator": {
      "description": "Primary workflow orchestrator that coordinates phases and delegates work without editing code.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "{file:./prompts/orchestrator.txt}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "pwd*": "allow",
          "ls*": "allow",
          "dir*": "allow",
          "tree*": "allow",
          "find*": "allow",
          "rg *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "Get-Location*": "allow",
          "Get-ChildItem*": "allow",
          "Get-Content*": "allow",
          "Select-String*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny",
          "implement": "allow",
          "review": "allow",
          "fix-issues": "allow"
        }
      }
    },
    "implement": {
      "description": "Implements only the current approved phase with minimal scoped changes and TDD discipline.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./prompts/implement.txt}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      }
    },
    "review": {
      "description": "Read-only review agent that checks plan alignment, scope, tests, and code quality for the current phase.",
      "mode": "subagent",
      "temperature": 0,
      "prompt": "{file:./prompts/review.txt}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "pwd*": "allow",
          "ls*": "allow",
          "dir*": "allow",
          "tree*": "allow",
          "find*": "allow",
          "rg *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "Get-Location*": "allow",
          "Get-ChildItem*": "allow",
          "Get-Content*": "allow",
          "Select-String*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "bun test*": "allow",
          "pytest*": "allow",
          "uv run pytest*": "allow",
          "go test*": "allow",
          "cargo test*": "allow",
          "dotnet test*": "allow",
          "make test*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      }
    },
    "fix-issues": {
      "description": "Fixes only explicit review findings for the current phase without adding scope or parallel refactors.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:./prompts/fix-issues.txt}",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      }
    }
  }
}
