{
  "name": "skills-manager",
  "version": "1.0.0",
  "description": "Desktop application for managing LLM skills across multiple IDEs with symlink-based organization",
  "main": ".vite/build/main.js",
  "author": "lucasparis55",
  "license": "MIT",
  "scripts": {
    "start": "electron-forge start",
    "build:main": "vite build --config src/main/vite.config.ts",
    "build:preload": "vite build --config src/preload/vite.config.ts",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "prod": "npm run build && electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "eslint": "^9.14.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "chokidar": "^4.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.10.3",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  }
}
